generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Assembler {
  id           String         @id @default(uuid())
  name         String
  internalRate Float
  externalRate Float
  serviceOrders ServiceOrder[]
}

enum ServiceType {
  INTERNAL
  EXTERNAL
}

model ServiceOrder {
  id              String      @id @default(uuid())
  assemblerId     String
  assembler       Assembler   @relation(fields: [assemblerId], references: [id])
  saleValue       Decimal
  commissionValue Decimal
  type            ServiceType
  description     String?
  location        String?
  serviceDate     DateTime
  createdAt       DateTime    @default(now())
}
